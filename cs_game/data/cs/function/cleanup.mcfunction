# --- МОДУЛЬ ОЧИСТКИ КАРТЫ ---

# 1. Удаляем все выпавшие предметы (дроп)
# Это исключает возможность "поднять" оружие из прошлого раунда бесплатно
kill @e[type=item]

# 2. Удаляем все застрявшие стрелы и снаряды
# Важно для производительности, так как сотни стрел в стенах создают лаги
kill @e[type=arrow]
kill @e[type=spectral_arrow]
kill @e[type=trident]

# 3. Очищаем визуальные эффекты
# Удаляем облака оседающих зелий (гранат), если они остались
kill @e[type=area_effect_cloud]